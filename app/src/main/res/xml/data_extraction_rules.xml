<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include Room Database and DataStore for Cloud Backup -->
        <include domain="database" path="school_bell_database"/>
        <include domain="file" path="datastore/school_bell_settings.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <!-- Include same for Device-to-Device transfer (e.g., Pixel setup) -->
        <include domain="database" path="school_bell_database"/>
        <include domain="file" path="datastore/school_bell_settings.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>
